# Telegram Bot Token
TELEGRAM_TOKEN=your_bot_token_here

# For servers.json configuration:
# Each server needs:
# - host: VPS IP address
# - username: SSH user
# - port: SSH port (default 22)
# - privateKeyPath: Path to SSH key (OR use password)
# - password: SSH password (alternative to key)

# Example servers.json structure:
# {
#   "prod-server": {
#     "host": "1.2.3.4",
#     "username": "root",
#     "port": 22,
#     "privateKeyPath": "/home/user/.ssh/id_rsa"
#   },
#   "staging": {
#     "host": "5.6.7.8",
#     "username": "deploy",
#     "port": 22,
#     "password": "your_password"
#   }
# }
